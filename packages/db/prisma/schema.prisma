generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
  TWITTER
  LINKEDIN
  XIAOHONGSHU
  REDDIT
}

enum AccountStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum WorkflowStepType {
  POST
  DELAY
  CONDITION
  NOTIFY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      SocialAccount[]
  posts         Post[]
  analytics     Analytics[]
  workflows     Workflow[]
  templates     ContentTemplate[]
}

model SocialAccount {
  id              String       @id @default(cuid())
  userId          String
  platform        Platform
  platformUserId  String
  username        String
  displayName     String?
  avatar          String?
  accessToken     String
  refreshToken    String?
  tokenExpiry     DateTime?
  status          AccountStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           Post[]
  analytics       Analytics[]
  workflowSteps   WorkflowStep[]

  @@unique([userId, platform, platformUserId])
}

model Post {
  id              String     @id @default(cuid())
  userId          String
  accountId      String
  workflowStepId  String?
  platform        Platform
  platformPostId  String?
  content         Json
  mediaUrls      String[]
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  workflowStep    WorkflowStep?  @relation(fields: [workflowStepId], references: [id])
}

model Analytics {
  id           String   @id @default(cuid())
  userId       String
  accountId    String
  platform     Platform
  date         DateTime @db.Date
  followers    Int      @default(0)
  following    Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  views       Int      @default(0)
  engagement  Float    @default(0)
  createdAt   DateTime @default(now())

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
}

model Workflow {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)
  triggerType String         @default("manual")
  config      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]

  @@index([userId, status])
}

model WorkflowStep {
  id          String           @id @default(cuid())
  workflowId  String
  accountId   String?
  type        WorkflowStepType
  order       Int              @default(0)
  config      Json
  result      Json?
  error       String?
  executedAt  DateTime?
  createdAt   DateTime        @default(now())

  workflow    Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  account     SocialAccount?  @relation(fields: [accountId], references: [id])
  posts       Post[]

  @@index([workflowId, order])
}

model ContentTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   Json
  platform  Platform?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}