{
  "name": "social-aggregator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/dashboard",
    "dev:storefront": "npm run dev -w apps/storefront",
    "build": "npm run build -w apps/dashboard",
    "build:all": "npm run build -w apps/dashboard && npm run build -w apps/storefront",
    "db:push": "npm run db:push -w packages/db",
    "db:studio": "npm run db:studio -w packages/db"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
