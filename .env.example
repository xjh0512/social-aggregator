# Database - Vercel 上在 Settings → Environment Variables 添加
DATABASE_URL="你的 PostgreSQL 连接字符串"

# NextAuth
NEXTAUTH_SECRET="生成一个随机字符串: openssl rand -base64 32"
NEXTAUTH_URL="https://你的项目名.vercel.app"

# Platform OAuth - 在 Settings 页面填入
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
META_APP_ID=""
META_APP_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""